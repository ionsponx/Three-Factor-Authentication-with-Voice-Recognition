# Ignore email credentials file
email.env

# Ignore local database files and keep only instance/.gitkeep
instance/*.db
instance/*.sqlite
instance/*.sqlite3
!instance/.gitkeep

# Ignore Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environment files
venv/
env/
.venv/
.python/
.tools/
pretrained_models/
*.zip

# Ignore log files
Users_login_time.csv

# Ignore user-generated or temporary files
*.log
*.pid
*.tmp
*.bak
*.webm
voice_templates/

# Ignore IDE-specific files (e.g., VS Code)
.vscode/
*.code-workspace

# Ignore OS-generated files
.DS_Store  # macOS
Thumbs.db  # Windows
