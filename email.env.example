# Copy this file to email.env for local development.
# By default, email delivery is disabled and OTPs are shown on the OTP page.
ENABLE_EMAIL_DELIVERY=false
FLASK_SECRET_KEY=replace-this-with-a-random-local-secret
DATABASE_URL=sqlite:///site.db

# Only needed when ENABLE_EMAIL_DELIVERY=true.
# For Gmail, use a Google app password rather than your normal Google password.
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-16-digit-google-app-password

# Optional SpeechBrain settings.
SPEECHBRAIN_MODEL_SOURCE=speechbrain/spkrec-ecapa-voxceleb
SPEECHBRAIN_MODEL_DIR=pretrained_models/spkrec-ecapa-voxceleb

# Higher values are slower but can tolerate more timing drift between voice samples.
DTW_WINDOW_FRAMES=200
